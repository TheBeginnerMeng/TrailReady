<!--
  TrailReady 步履无忧 — 主页模板
  三标签页：📋 行程 | 🎒 装备 | ✅ 清单
-->
<wxs module="utils" src="./tag-utils.wxs" />
<view class="page-container theme-root {{currentTheme === 'dark' ? 'theme-dark' : 'theme-nature'}}">
  <!-- ===== 标签栏 ===== -->
  <view class="tab-bar">
    <view class="tab {{activeTab==='trip'?'tab-active':''}}" bindtap="switchTab" data-tab="trip">
      <text>📋 行程</text>
    </view>
    <view class="tab {{activeTab==='gear'?'tab-active':''}}" bindtap="switchTab" data-tab="gear">
      <text>🎒 装备<text class="tab-count">{{gear.length}}</text></text>
    </view>
    <view class="tab {{activeTab==='packing'?'tab-active':''}}" bindtap="switchTab" data-tab="packing">
      <text>✅ 清单<text class="tab-count" wx:if="{{result}}">{{packedCount}}/{{result.items.length}}</text></text>
    </view>
    <!-- 🎨 主题一键切换 -->
    <view class="theme-toggle-btn" bindtap="onToggleTheme">
      <text>{{currentTheme === 'dark' ? '🏔️ 山野' : '🤖 机甲'}}</text>
    </view>
  </view>

  <!-- =================================================================== -->
  <!-- 📋 行程标签页 -->
  <!-- =================================================================== -->
  <scroll-view wx:if="{{activeTab==='trip'}}" scroll-y enhanced show-scrollbar="{{false}}" class="tab-scroll">
    <view class="section-gap">

      <!-- —— 日期 + 天数控制 —— -->
      <view class="glass-card">
        <view class="card-head">
          <text class="card-head-icon">📅</text>
          <text class="card-head-label">出发日期 & 徒步天数</text>
        </view>
        <view class="date-row">
          <picker mode="date" value="{{startDate}}" bindchange="onStartDateChange">
            <view class="date-picker-btn">
              <text>{{startDate}}</text>
              <text class="arrow-down">▾</text>
            </view>
          </picker>
          <view class="date-sep">|</view>
          <view class="days-control">
            <view class="days-btn {{totalDays<=1?'days-btn-disabled':''}}" bindtap="onDaysMinus">−</view>
            <input type="number" value="{{totalDays}}" bindinput="onDaysInput" class="days-input" />
            <view class="days-btn {{totalDays>=7?'days-btn-disabled':''}}" bindtap="onDaysPlus">+</view>
            <text class="days-unit">天</text>
          </view>
        </view>
        <view class="date-range-hint">{{tripDateRange}}</view>
        <view class="forecast-hint {{dateExceedsForecast?'forecast-hint-warn':''}}">💡 步履提示：本工具已打通 30 天硬核气象雷达，支持查询【未来 30 天内】的动态天气与打包推荐。行程越近，预报越准哦！</view>
        <view wx:if="{{dateExceedsForecast}}" class="forecast-warning">⚠️ 您选择的日期已超出气象预报范围，届时系统将为您切换为默认"经典气候模型"进行装备推荐。</view>
      </view>

      <!-- —— 每日行程卡片 —— -->
      <view wx:for="{{dayPlans}}" wx:key="dayIndex" class="glass-card day-card">
        <!-- 日期标签 -->
        <view class="day-card-header">
          <view class="day-badge">
            <text>Day {{item.dayIndex}}</text>
          </view>
          <text class="day-date-text">· {{item.displayDate}}</text>
        </view>

        <!-- 目的地输入 -->
        <view class="dest-wrap">
          <view class="dest-row">
            <text class="dest-pin">📍</text>
            <input 
              placeholder="🔍 输入你想去的目的地/景区（如：雨崩、香格里拉）" 
              value="{{item.destination}}" 
              data-index="{{index}}"
              bindinput="onDestinationInput"
              bindfocus="onDestinationFocus"
              class="dest-input"
              placeholder-class="dest-placeholder"
            />
          </view>
          <!-- 🔍 城市联想下拉浮层 -->
          <view wx:if="{{suggestions[index] && suggestions[index].length >= 0}}" class="suggestions-dropdown" catchtap="noop">
            <view wx:if="{{suggestionsLoadingIndex === index}}" class="suggestions-loading">
              <text>⏳ 模糊搜索中...</text>
            </view>
            <view wx:elif="{{suggestions[index].length === 0}}" class="suggestion-no-result">
              <text>未找到匹配的目的地</text>
            </view>
            <block wx:else>
              <view 
                wx:for="{{suggestions[index]}}" 
                wx:key="id" 
                wx:for-item="city"
                wx:for-index="sidx"
                class="suggestion-item"
                catchtap="onSelectCity"
                data-day-index="{{index}}"
                data-city="{{city}}"
              >
                <text class="suggestion-icon">📍</text>
                <view class="suggestion-info">
                  <text class="suggestion-name">{{city.name}}</text>
                  <text class="suggestion-address" wx:if="{{city.address}}">{{city.address}}</text>
                </view>
              </view>
            </block>
          </view>
        </view>

        <!-- 天气模拟区域 -->
        <view wx:if="{{weatherLoadingIndex===index}}" class="weather-loading">
          <text>⏳ 正在获取 {{item.dateString}} 天气…</text>
        </view>
        <view wx:elif="{{item.simulatedWeather}}" class="weather-result">
          <text class="weather-icon">{{item.simulatedWeather.icon}}</text>
          <text class="weather-text">{{item.simulatedWeather.description}} {{item.simulatedWeather.tempRange}}</text>
          <view class="weather-tags">
            <text wx:for="{{item.simulatedWeather.conditions}}" wx:key="*this" class="weather-tag">{{item}}</text>
          </view>
        </view>
        <view wx:else class="weather-idle">
          <text>输入目的地后将自动获取天气</text>
        </view>

        <!-- 天气预设选择器 -->
        <picker 
          range="{{weatherPresetOptions}}" 
          range-key="label"
          value="{{item.weatherPresetIndex}}"
          bindchange="onWeatherPresetChange" 
          data-index="{{index}}"
        >
          <view class="preset-picker">
            <text class="preset-icon">🌡️</text>
            <text class="preset-label">{{weatherPresetOptions[item.weatherPresetIndex].label}}</text>
            <text class="preset-arrow">▾</text>
            <text class="preset-action">手动覆盖</text>
          </view>
        </picker>

        <!-- 本日住宿方式 -->
        <view class="stay-toggle-row">
          <text class="stay-toggle-label">住宿方式</text>
          <view class="stay-toggle-group">
            <view 
              class="stay-toggle-btn {{item.stayType==='hotel'?'stay-toggle-hotel':''}}" 
              bindtap="onStayTypeToggle" 
              data-index="{{index}}" 
              data-type="hotel"
            >
              <text>🏨 旅馆</text>
            </view>
            <view 
              class="stay-toggle-btn {{item.stayType==='camping'?'stay-toggle-camp':''}}" 
              bindtap="onStayTypeToggle" 
              data-index="{{index}}" 
              data-type="camping"
            >
              <text>⛺ 扎营</text>
            </view>
          </view>
        </view>
      </view>

      <!-- 实时联动指示器 -->
      <view class="live-badge">
        <view class="live-dot"></view>
        <text>实时联动 — 修改任意数据即刻刷新右侧清单</text>
      </view>
    </view>
  </scroll-view>

  <!-- =================================================================== -->
  <!-- 🎒 装备库标签页 -->
  <!-- =================================================================== -->
  <scroll-view wx:if="{{activeTab==='gear'}}" scroll-y enhanced show-scrollbar="{{false}}" class="tab-scroll">
    <view class="section-gap">

      <!-- 添加按钮 -->
      <view class="gear-add-btn" bindtap="onTapAddGear">
        <text>＋ 添加新装备</text>
      </view>

      <!-- 空状态 -->
      <view wx:if="{{gear.length===0}}" class="gear-empty">
        <text class="gear-empty-icon">🎒</text>
        <text class="gear-empty-text">装备库为空</text>
        <text class="gear-empty-sub">点击上方按钮添加你的第一件装备</text>
      </view>

      <!-- 按分类分组 -->
      <block wx:for="{{gearGrouped}}" wx:key="category">
        <view class="gear-group">
          <!-- 分类标题 -->
          <view class="gear-cat-head" bindtap="onToggleCategory" data-cat="{{item.category}}">
            <text class="gear-cat-icon">{{item.icon}}</text>
            <text class="gear-cat-label">{{item.label}}</text>
            <text class="gear-cat-meta">{{item.items.length}}件 · {{item.totalWeight}}g</text>
            <text class="gear-cat-arrow">{{item.expanded ? '▴' : '▾'}}</text>
          </view>

          <!-- 装备项 -->
          <view wx:if="{{item.expanded}}" class="gear-items">
            <view wx:for="{{item.items}}" wx:key="id" wx:for-item="gi" class="gear-item">
              <view class="gear-item-info">
                <text class="gear-item-name">{{gi.name}}</text>
                <view class="gear-item-tags">
                  <text wx:for="{{gi.tags}}" wx:key="*this" wx:for-item="tag" class="tag-badge tag-{{tag}}">{{tag}}</text>
                </view>
              </view>
              <view class="gear-item-meta">
                <text class="gear-item-weight">{{gi.weight}}g</text>
                <view class="gear-item-actions">
                  <view class="gear-action-btn gear-action-edit" bindtap="onTapEditGear" data-id="{{gi.id}}">
                    <text>✏️</text>
                  </view>
                  <view class="gear-action-btn gear-action-del" bindtap="onDeleteGear" data-id="{{gi.id}}">
                    <text>🗑️</text>
                  </view>
                </view>
              </view>
            </view>
          </view>
        </view>
      </block>

      <!-- 底部统计 -->
      <view wx:if="{{gear.length>0}}" class="gear-footer">
        <text>共 {{gearCount}} 件装备 · 总重 {{gearWeight}}g</text>
      </view>
    </view>
  </scroll-view>

  <!-- =================================================================== -->
  <!-- ✅ 打包清单标签页 -->
  <!-- =================================================================== -->
  <scroll-view wx:if="{{activeTab==='packing'}}" scroll-y enhanced show-scrollbar="{{false}}" class="tab-scroll">
    <view class="section-gap">

      <!-- 空状态：未配置目的地 -->
      <view wx:if="{{!result}}" class="packing-empty">
        <text class="packing-empty-icon">📦</text>
        <text class="packing-empty-title">暂无打包清单</text>
        <text class="packing-empty-desc">请在左侧输入正确的地点以刷新天气与清单。</text>
      </view>

      <block wx:if="{{result}}">
        <!-- 行程摘要 -->
        <view class="glass-card">
          <view class="card-head">
            <text class="card-head-icon">🗺️</text>
            <text class="card-head-label">行程摘要</text>
          </view>
          <view class="summary-row">
            <text class="summary-label">行程时间</text>
            <text class="summary-value">{{tripDateRange}}</text>
          </view>
          <view class="summary-row">
            <text class="summary-label">目的地</text>
            <text class="summary-value">{{destinationChain || '未设定'}}</text>
          </view>
          <view class="summary-row">
            <text class="summary-label">住宿模式</text>
            <text class="summary-value">{{smartLodgeHint}}</text>
          </view>
        </view>

        <!-- 智能宿营看板 -->
        <view wx:if="{{smartBoardText}}" class="smart-board">
          <text>{{smartBoardText}}</text>
        </view>

        <!-- 重量与温度仪表盘 -->
        <view class="glass-card">
          <view class="dashboard-grid">
            <view class="dash-item dash-weight">
              <text class="dash-num accent">{{totalWeightDisplay}}</text>
              <text class="dash-label">预估总重</text>
            </view>
            <view class="dash-item dash-temp">
              <text class="dash-num">{{result.climateSummary.minTemp}}~{{result.climateSummary.maxTemp}}°C</text>
              <text class="dash-label">全程温度范围</text>
            </view>
          </view>
        </view>

        <!-- 气候挑战 -->
        <view wx:if="{{result.climateSummary.challenges.length>0}}" class="glass-card climate-card">
          <view class="card-head">
            <text class="card-head-icon">🌍</text>
            <text class="card-head-label">气候挑战</text>
          </view>
          <view wx:for="{{result.climateSummary.challenges}}" wx:key="*this" class="climate-item">
            <text>{{item}}</text>
          </view>
        </view>

        <!-- 警告 -->
        <view wx:if="{{result.warnings.length>0}}" class="warnings-card">
          <view class="card-head">
            <text class="card-head-icon">⚠️</text>
            <text class="card-head-label">注意事项</text>
          </view>
          <view wx:for="{{result.warnings}}" wx:key="*this" class="warning-item">
            <text>{{item}}</text>
          </view>
        </view>

        <!-- 提示消息 -->
        <view wx:if="{{result.infoMessages.length>0}}" class="glass-card info-card">
          <view wx:for="{{result.infoMessages}}" wx:key="*this" class="info-item">
            <text>{{item}}</text>
          </view>
        </view>

        <!-- 打包进度条 -->
        <view class="progress-wrap">
          <view class="progress-bar">
            <view class="progress-fill" style="width: {{packedPercent}}%"></view>
          </view>
          <text class="progress-text">已打包 {{packedCount}}/{{result.items.length}} 件 · {{packedWeight}}g/{{totalWeightDisplay}}（{{packedPercent}}%）</text>
        </view>

        <!-- 打包清单 —— 按分类分组 -->
        <block wx:for="{{packingGrouped}}" wx:key="category">
          <view class="pack-group">
            <view class="pack-cat-head" bindtap="onTogglePackCategory" data-cat="{{item.category}}">
              <text class="pack-cat-icon">{{item.icon}}</text>
              <text class="pack-cat-label">{{item.label}}</text>
              <text class="pack-cat-meta">{{item.packed}}/{{item.total}}件 · {{item.catWeight}}g</text>
              <text class="gear-cat-arrow">{{item.expanded ? '▴' : '▾'}}</text>
            </view>

            <view wx:if="{{item.expanded}}" class="pack-items">
              <view wx:for="{{item.items}}" wx:key="id" wx:for-item="pi" class="pack-item {{pi.packed?'pack-item-done':''}}">
                <view class="pack-check {{pi.packed?'pack-check-on':''}}" bindtap="onTogglePacked" data-id="{{pi.id}}">
                  <text wx:if="{{pi.packed}}">✓</text>
                </view>
                <view class="pack-item-info">
                  <text class="pack-item-name {{pi.packed?'strikethrough':''}}">{{pi.name}}</text>
                  <text wx:if="{{pi.quantity>1}}" class="pack-item-qty">×{{pi.quantity}}</text>
                  <text wx:if="{{pi.reason}}" class="pack-item-reason">{{pi.reason}}</text>
                </view>
                <text class="pack-item-wt">{{pi.weight * pi.quantity}}g</text>
              </view>
            </view>
          </view>
        </block>
      </block>
    </view>
  </scroll-view>

  <!-- =================================================================== -->
  <!-- 🪟 装备编辑模态框 -->
  <!-- =================================================================== -->
  <view wx:if="{{modalVisible}}" class="modal-mask {{modalClosing?'modal-mask-out':''}}" bindtap="closeModal">
    <view class="modal-panel {{modalClosing?'modal-panel-out':''}}" catchtap="noop">
      <!-- 标题 -->
      <view class="modal-head">
        <text class="modal-title">{{editingId?'编辑装备':'添加新装备'}}</text>
        <view class="modal-close" bindtap="closeModal"><text>✕</text></view>
      </view>

      <!-- 名称 -->
      <view class="form-group">
        <text class="form-label">装备名称 <text class="form-required">*</text></text>
        <input 
          placeholder="例如：Arc'teryx Beta LT 冲锋衣" 
          value="{{formName}}" 
          bindinput="onFormNameInput"
          class="form-input" 
          placeholder-class="form-placeholder"
        />
      </view>

      <!-- 分类 + 重量 -->
      <view class="form-row">
        <view class="form-group flex-1">
          <text class="form-label">装备分类</text>
          <picker range="{{gearCategoryOptions}}" range-key="label" value="{{formCategoryIndex}}" bindchange="onFormCategoryChange">
            <view class="form-picker">
              <text>{{formCategoryLabel}}</text>
              <text class="form-picker-arrow">▾</text>
            </view>
          </picker>
        </view>
        <view class="form-group flex-1">
          <text class="form-label">重量 <text class="form-required">*</text></text>
          <view class="form-weight-wrap">
            <input 
              type="number" 
              placeholder="0" 
              value="{{formWeight}}" 
              bindinput="onFormWeightInput"
              class="form-input form-input-wt" 
              placeholder-class="form-placeholder"
            />
            <text class="form-wt-unit">g</text>
          </view>
        </view>
      </view>

      <!-- 核心标签 -->
      <view class="form-group">
        <text class="form-label">核心标签</text>
        <view class="form-tags-grid">
          <view 
            wx:for="{{allTags}}" 
            wx:key="*this" 
            wx:for-item="tag"
            class="form-tag {{utils.includes(formTags,tag)?'form-tag-sel':''}}"
            bindtap="onToggleTag"
            data-tag="{{tag}}"
          >
            <text class="{{utils.includes(formTags,tag)?'form-tag-sel-text':''}}">{{tag}}</text>
          </view>
        </view>
      </view>

      <!-- 错误提示 -->
      <view wx:if="{{formError}}" class="form-error">
        <text>{{formError}}</text>
      </view>

      <!-- 按钮 -->
      <view class="form-actions">
        <view class="btn-secondary flex-1" bindtap="closeModal"><text>取消</text></view>
        <view class="btn-primary flex-1" bindtap="onSaveGear"><text>{{editingId?'保存修改':'加入装备库'}}</text></view>
      </view>
    </view>
  </view>

  <!-- 🔒 下拉联想全屏透明遮罩：脱离 scroll-view，position:fixed 可靠生效 -->
  <!--    点击遮罩仅关闭下拉，绝对不触发任何查询 -->
  <view wx:if="{{suggestionMaskVisible}}" class="suggestion-mask" catchtap="hideAllSuggestions"></view>
</view>
